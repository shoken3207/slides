{
  "name": "my-lt-template",
  "version": "1.0.0",
  "private": true,
  "config": {
    "slidesBaseUrl": "https://shoken3207.github.io/slides"
  },
  "scripts": {
    "dev": "marp --preview -c marp.config.mjs",
    "build": "bash scripts/build.sh",
    "build:pdf": "marp -c marp.config.mjs --pdf --allow-local-files -o dist/",
    "build:pptx": "marp -c marp.config.mjs --pptx --allow-local-files -o dist/"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4",
    "qrcode": "^1.5.4"
  }
}
